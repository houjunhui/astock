MIN(date), MAX(date) FROM predictions')\nprint('\\n日期范围:', cur.fetchone())\n\n# 检查historical_zt的lb字段（涨停连板数）\ncur.execute('SELECT lb, COUNT(*) FROM historical_zt GROUP BY lb ORDER BY lb')\nprint('\\nhistorical_zt lb分布:')\nfor row in cur.fetchall():\n    print(f'  lb={row[0]}: {row[1]}')\n\n# 看historical_zt outcome字段\ncur.execute('PRAGMA table_info(historical_zt)')\nprint('\\nhistorical_zt columns:')\nfor c in cur.fetchall():\n    print(f'  {c[1]} {c[2]}')\n\"\n","timeout":15}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":12442,"output":538,"cacheRead":25966,"cacheWrite":0,"totalTokens":38946,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774284430774}}
