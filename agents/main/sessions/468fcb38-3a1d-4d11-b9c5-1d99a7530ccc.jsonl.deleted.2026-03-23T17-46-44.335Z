ist.append(0)\n-301             auction_bid_list.append(0)\n-302             volume_ratio_list.append(1)\n-303 \n-304     data['auction_chng'] = auction_chng_list\n-305     data['auction_bid'] = auction_bid_list\n-306     data['auction_volume_ratio'] = volume_ratio_list\n+268     # 注意：历史竞价数据无法批量获取，使用 jb_prob/adj_factor 作为代理\n+269     print(\"[特征] 竞价特征（使用jb_prob代理）...\")\n+270     # 从jb_prob推断竞价强度：jb_prob高 → 竞价强势\n+271     data['auction_chng'] = (data['jb_prob'] / 15).clip(-5, 10)  # 代理：jb_prob->竞价涨幅\n+272     data['auction_bid'] = (data['adj_factor'] * 500).clip(0, 5000)  # 代理：adj_factor->封单\n+273     data['auction_volume_ratio'] = data['vr'].clip(0.5, 3.0)  # 用vr代理竞价量比\n 307     data['log_auction_bid'] = np.log1p(data['auction_bid'])\n 308 \n 309     # 竞价信号特征\n 310     data['auction_high'] = (data['auction_chng'] > 5).astype(int)\n     ...","firstChangedLine":268},"isError":false,"timestamp":1774285001674}}
