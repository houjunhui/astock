0320')\nprint(f\"涨停股数量: {len(zt_df)}\")\n\n# 行业联动\nsector_counts = zt_df.groupby('所属行业').size().to_dict()\n\nresults = []\n\nfor _, row in zt_df.iterrows():\n    code = str(row['代码']).zfill(6)\n    name = row['名称']\n    lb = int(row['连板数'])\n    sector = row['所属行业']\n    sector_hot = sector_counts.get(sector, 0) >= 3\n    \n    try:\n        kl = get_kline(code, days=120)\n        if kl is None:\n            continue\n        \n        vr = kl.get('vr')\n        if vr is None:\n            vr = 1.0  # fallback\n        \n        # phase = 正常 (中性市场)\n        pred = predict_stock(code, lb, kl, phase='正常')\n        jb_prob = pred['jb_prob']\n        \n        ok_min, ok_max, vol_req, warning = auction_ok(code, name, lb, jb_prob, vr, sector_hot=sector_hot, phase='正常')\n        \n        # 筛选: ok_min <= 8 AND vr >= 0.5\n        if ok_min <= 8 and vr >= 0.5:\n            qualify = True\n        else:\n            qualify = False\n        \n        results.append({\n            'code': code,\n            'name': name,\n            'lb': lb,\n            'sector': sector,\n            'jb_prob': jb_prob,\n            'ok_min': ok_min,\n            'ok_max': ok_max,\n            'vr': vr,\n            'sector_hot': sector_hot,\n            'qualify': qualify,\n            'rsi': kl.get('rsi'),\n            'trend': kl.get('trend'),\n            'last_close': kl.get('last_close'),\n            'warning': warning,\n        })\n        \n    except Exception as e:\n        print(f\"  {code} {name}: Error - {e}\")\n    \n    time.sleep(0.1)\n\nbs.logout()\n\nprint(f\"\\n处理完成: {len(results)}只\")\n\n# 筛选结果\nqualified = [r for r in results if r['qualify']]\nprint(f\"符合竞价条件: {len(qualified)}只\")\n\n# 按jb_prob排序\nqualified.sort(key=lambda x: x['jb_prob'], reverse=True)\nprint(\"\\n重点竞价（按晋级概率排序）:\")\nfor r in qualified[:15]:\n    vr_str = f\"{r['vr']:.2f}\" if r['vr'] else \"N/A\"\n    print(f\"  {r['code']} {r['name']} LB{r['lb']} Prob={r['jb_prob']}% Range={r['ok_min']}~{r['ok_max']}% VR={vr_str} Sector={r['sector']}\")\n\n# 晋级概率分布\nhigh = [r for r in qualified if r['jb_prob'] >= 30]\nmid = [r for r in qualified if 15 <= r['jb_prob'] < 30]\nlow = [r for r in qualified if r['jb_prob'] < 15]\nprint(f\"\\n晋级概率分布:\")\nprint(f\"  >30%: {len(high)}只\")\nprint(f\"  15-30%: {len(mid)}只\")\nprint(f\"  <15%: {len(low)}只\")\n\n# 板块联动\nprint(\"\\n板块联动:\")\nhot_sectors = {}\nfor r in qualified:\n    if r['sector_hot']:\n        s = r['sector']\n        if s not in hot_sectors:\n            hot_sectors[s] = []\n        hot_sectors[s].append(r)\nfor s, stocks in hot_sectors.items():\n    print(f\"  {s}: {len(stocks)}只\")\n\n# 保存\nwith open('/tmp/auction_results.json', 'w') as f:\n    json.dump(results, f, ensure_ascii=False, indent=2)\nPYEOF","yieldMs":120000,"timeout":180}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":15178,"output":1315,"cacheRead":27169,"cacheWrite":0,"totalTokens":43662,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774229391572}}
