{"type":"message","id":"ce4c7ad3","parentId":"acac5674","timestamp":"2026-03-23T00:26:00.506Z","message":{"role":"toolResult","toolCallId":"call_function_sr3n8tb18g3z_1","toolName":"read","content":[{"type":"text","text":"\"\"\"\nastock.auction\n竞价条件判断 - 智能窄区间版本\n\"\"\"\n\n# ---------- 辅助函数 ----------\n\n\ndef _round_center(val, step=0.5):\n    \"\"\"四舍六入到step的整数倍，更自然\"\"\"\n    return round(val / step) * step\n\n\n# ---------- 核心智能计算 ----------\n\n\ndef calc_auction_range(lb, jb_prob, vr=None, sector_hot=False, phase=\"退潮\"):\n    \"\"\"\n    综合多因素计算竞价区间。\n    返回 (ok_min, ok_max, vol_req, warning, reasoning)\n\n    参数:\n        lb: 连板数（1-6+）\n        jb_prob: 晋级概率（%），已校准\n        vr: 量比（可选）\n        sector_hot: 板块是否≥3只联动\n        phase: 市场阶段（退潮/冰点/启动/发酵）\n\n    区间宽度目标：≤2.5pp（最优≤2pp）\n    \"\"\"\n    reasoning = []\n\n    # ---- 基础区间（根据板位） ----\n    if lb >= 5:\n        base_min, base_max = 0.5, 3.0\n        reasoning.append(\"5板+，控盘区\")\n    elif lb == 4:\n        base_min, base_max = 1.0, 4.0\n        reasoning.append(\"4板，高位控盘\")\n    elif lb == 3:\n        base_min, base_max = 1.5, 4.5\n        reasoning.append(\"3板，关键分岐位\")\n    elif lb == 2:\n        base_min, base_max = 2.0, 5.0\n        reasoning.append(\"2板，加速期\")\n    else:  # lb == 1\n        base_min, base_max = 2.5, 5.5\n        reasoning.append(\"1板，首板观察\")\n\n    # ---- 晋级概率调整 ----\n    prob = jb_prob  # 已经是%\n    if prob >= 35:\n        # 高概率：区间收窄并下调上限（价格已反映预期，竞价不宜过高）\n        adj = -0.5\n        reasoning.append(f\"高概率{prob:.0f}%→收窄\")\n    elif prob >= 25:\n        adj = 0.0\n        reasoning.append(f\"中高概率{prob:.0f}%→标准\")\n    elif prob >= 18:\n        adj = +0.3\n        reasoning.append(f\"中概率{prob:.0f}%→略宽\")\n    else:\n        adj = +0.5\n        reasoning.append(f\"低概率{prob:.0f}%→从宽\")\n\n    base_min += adj\n    base_max += adj\n\n    # ---- 量比(VR)调整 ----\n    vol_req = \"平量/缩量\"\n    if vr is not None:\n        if vr < 0.5:\n            # 极度缩量：区间下限下调，上限收紧（主力控盘，竞价不应高开）\n            base_min = max(0.5, base_min - 1.0)\n            base_max = base_max - 0.5\n            vol_req = \"极度缩量优先\"\n            reasoning.append(f\"VR={vr:.2f}极度缩量→控盘信号\")\n        elif vr < 0.8:\n            # 缩量：下限略降\n            base_min = max(1.0, base_min - 0.5)\n            base_max = base_max - 0.3\n            vol_req = \"缩量/平量\"\n            reasoning.append(f\"VR={vr:.2f}缩量→控盘偏好\")\n        elif vr > 2.0:\n            # 放量：区间整体上移，防范砸盘\n            base_min = base_min + 0.5\n            base_max = base_max + 0.5\n            vol_req = \"需明显放量\"\n            reasoning.append(f\"VR={vr:.2f}放量→区间上调\")\n        elif vr > 1.5:\n            base_min = base_min + 0.3\n            base_max = base_max + 0.3\n            vol_req = \"温和放量\"\n            reasoning.append(f\"VR={vr:.2f}温和放量→量能支撑\")\n\n    # ---- 板块联动加成 ----\n    if sector_hot:\n        # 有板块联动：区间略收窄，下限略降（板块热度提供缓冲）\n        base_min = max(1.0, base_min - 0.3)\n        base_max = base_max - 0.2\n        reasoning.append(\"🚀板块联动→热度缓冲\")\n\n    # ---- 市场阶段调整 ----\n    if phase == \"退潮\":\n        base_min = max(1.0, base_min)\n        base_max = base_max - 0.5\n        reasoning.append(\"退潮期→防御优先\")\n    elif phase == \"冰点\":\n        base_min = max(1.0, base_min)\n        base_max = base_max - 0.3\n        reasoning.append(\"冰点期→极度防御\")\n    elif phase == \"发酵\":\n        base_min = base_min - 0.3\n        base_max = base_max + 0.3\n        reasoning.append(\"发酵期→进攻窗口\")\n    # 启动期不做调整\n\n    # ---- 最终clamp + 取整 ----\n    ok_min = max(0.0, round(base_min * 2) / 2)  # 0.5的整数倍\n    ok_max = max(ok_min + 1.0, round(base_max * 2) / 2)\n    ok_max = min(ok_max, 8.0)  # 上限不超过8%\n\n    # ---- 生成警告 ----\n    warning = _build_warning(lb, ok_min, ok_max, jb_prob, vr, phase, sector_hot)\n\n    return ok_min, ok_max, vol_req, warning, \"; \".join(reasoning)\n\n\ndef _build_warning(lb, ok_min, ok_max, jb_prob, vr, phase, sector_hot):\n    \"\"\"生成风险提示\"\"\"\n    parts = []\n\n    # 高板位特殊警告\n    if lb >= 4:\n        if ok_max >= 4:\n            parts.append(f\"⚠️{lb}板位：竞价>{ok_max:.0f}%慎防获利盘砸盘\")\n        if ok_min <= 1:\n            parts.append(f\"竞价<{ok_min:.0f}%→情绪偏弱接力不足\")\n    elif lb == 3:\n        parts.append(\"⚠️3板分岐位：竞价过高易炸板\")\n\n    # 低概率警告\n    if jb_prob < 15:\n        parts.append(f\"❌晋级率{jb_prob:.0f}%偏低：需竞价强劲({ok_min:.0f}~{ok_max:.0f}%)才考虑\")\n\n    # 超买警告\n    if vr is not None and vr > 2.0:\n        parts.append(\"⚠️VR偏高：需充分换手才能封板\")\n\n    # 市场阶段警告\n    if phase in (\"退潮\", \"冰点\"):\n        parts.append(f\"⚠️当前{phase}期：控制仓位\")\n\n    # 正面信号\n    if not parts:\n        if sector_hot:\n            parts.append(\"✅板块联动+情绪支持\")\n        elif jb_prob >= 25:\n            parts.append(\"✅晋级概率良好\")\n\n    return \" | \".join(parts) if parts else \"观察\"\n\n\n# ---------- 对外接口（兼容旧调用） ----------\n\n\ndef auction_ok(code, name, lb, jb_prob, vr=None, sector_hot=False, phase=\"退潮\"):\n    \"\"\"\n    生成竞价观察条件说明（兼容旧接口）。\n    返回 (ok_min, ok_max, vol_req, warning)\n    \"\"\"\n    ok_min, ok_max, vol_req, warning, _ = calc_auction_range(\n        lb, jb_prob, vr, sector_hot, phase\n    )\n    return ok_min, ok_max, vol_req, warning\n"}],"isError":false,"timestamp":1774225560495}}
{"type":"message","id":"1094d2a6","parentId":"ce4c7ad3","timestamp":"2026-03-23T00:26:00.518Z","message":{"role":"toolResult","toolCallId":"call_function_sr3n8tb18g3z_2","toolName":"read","content":[{"type":"text","text":"\"\"\"\nastock.predict\n预测核心 - 晋级概率计算 + 信号生成\n\"\"\"\nfrom config import BASE_PROBS, DEFAULT_COEF, PHASE_BASE_DISCOUNT\n\n\ndef load_coef():\n    \"\"\"加载系数配置（可后续扩展为文件持久化）\"\"\"\n    return dict(DEFAULT_COEF)\n\n\ndef calc_adj(trend, vr, dif, macd_val, rsi_val, cur, ma20, ma60, lb, coef=None):\n    \"\"\"\n    计算综合调整系数。\n    所有因子相乘得到总系数。\n    \"\"\"\n    if coef is None:\n        coef = load_coef()\n\n    f = 1.0\n    f *= coef.get(trend, 1.0)\n\n    if vr is not None:\n        if vr < 0.5:\n            f *= coef.get('vr_<0.5', 1.0)\n        elif vr < 0.8:\n            f *= coef.get('vr_<0.8', 1.0)\n        elif vr < 1.0:\n            f *= coef.get('vr_<1.0', 1.0)\n        elif vr < 1.5:\n            f *= coef.get('vr_<1.5', 1.0)\n        else:\n            f *= coef.get('vr_>=1.5', 1.0)\n\n    if rsi_val is not None:\n        if rsi_val < 40:\n            f *= coef.get('rsi_<40', 1.0)\n        elif rsi_val < 50:\n            f *= coef.get('rsi_<50', 1.0)\n        elif rsi_val < 60:\n            f *= coef.get('rsi_<60', 1.0)\n        elif rsi_val < 70:\n            f *= coef.get('rsi_<70', 1.0)\n        else:\n            f *= coef.get('rsi_>=70', 1.0)\n\n    dif_de_cross = None\n    if dif is not None and macd_val is not None:\n        dif_de_cross = '底部金叉' if (dif > 0 and macd_val > 0) else ('顶部死叉' if (dif < 0 and macd_val < 0) else None)\n    if dif_de_cross:\n        f *= coef.get(dif_de_cross, 1.0)\n\n    if cur is not None and ma20 is not None:\n        f *= coef.get('ma20上方', 1.0) if cur > ma20 else coef.get('ma20下方', 1.0)\n\n    lb_key = {1: '首板', 2: '2板', 3: '3板', 4: '4板', 5: '5板+'}.get(lb, '首板')\n    f *= coef.get(lb_key, 1.0)\n\n    return max(0.1, min(f, 3.0))\n\n\ndef build_signal(kl):\n    \"\"\"从K线指标生成信号描述列表\"\"\"\n    signals = []\n    if kl.get('trend') == '上升通道':\n        signals.append('上升通道')\n    elif kl.get('trend') == '下降通道':\n        signals.append('下降通道')\n    if kl.get('rsi'):\n        if kl['rsi'] < 40:\n            signals.append('RSI超卖')\n        elif kl['rsi'] > 70:\n            signals.append('RSI超买')\n        elif kl['rsi'] < 50:\n            signals.append('RSI偏弱')\n    if kl.get('macd_state'):\n        signals.append(kl['macd_state'])\n    if kl.get('vol_status') in ('极度缩量', '温和缩量'):\n        signals.append('缩量')\n    if kl.get('vol_status') == '极度缩量':\n        signals.append('极度缩量')\n    if kl.get('price_vs_ma20') == 'MA20上方':\n        signals.append('MA20上方')\n    return signals\n\n\ndef calc_distribution(lb, adj):\n    \"\"\"\n    计算N板/N+1板/N+2板的晋级概率分布。\n    adj是综合调整系数。\n    \"\"\"\n    next_lb = min(lb + 1, 5)\n    next2_lb = min(lb + 2, 5)\n\n    base_next = BASE_PROBS.get(next_lb, 0.10)\n    base_next2 = BASE_PROBS.get(next2_lb, 0.05)\n\n    # 调整后概率（有上限）\n    p_continue = min(base_next * adj * 0.7, 0.80)\n    p_jb = base_next * adj\n    p_jb = min(p_jb, 0.70)\n\n    return {\n        1: round((1 - p_jb) * 100, 1),\n        2: round(p_jb * 50, 1),\n        3: round(p_jb * 30, 1),\n        4: round(p_jb * 15, 1),\n        5: round(p_jb * 5, 1),\n    }\n\n\ndef predict_stock(code, lb, kl, coef_override=None, phase=None):\n    \"\"\"\n    给定股票代码、连板数、K线数据，返回预测结果dict。\n    \"\"\"\n    coef = coef_override or load_coef()\n\n    cur = kl.get('last_close')\n    ma20 = kl.get('ma20')\n    ma60 = kl.get('ma60')\n    rsi_val = kl.get('rsi')\n    vr = kl.get('vr')\n    dif = kl.get('dif')\n    macd_val = kl.get('macd')\n\n    adj = calc_adj(\n        kl.get('trend', '震荡'), vr, dif, macd_val, rsi_val,\n        cur, ma20, ma60, lb, coef\n    )\n\n    base = BASE_PROBS.get(min(lb + 1, 5), 0.10)\n\n    # 情绪周期折扣\n    discount = 1.0\n    if phase:\n        discount = PHASE_BASE_DISCOUNT.get(phase, 1.0)\n\n    jb_prob = round(min(base * adj * discount, 0.70) * 100, 1)\n    dz_prob = round(min(base * adj * 0.5 * discount, 0.30) * 100, 1)\n\n    dist = calc_distribution(lb, adj)\n    signal = ', '.join(build_signal(kl))\n\n    return {\n        'jb_prob': jb_prob,\n        'dz_prob': dz_prob,\n        'base_prob': round(base * 100, 1),\n        'adj_factor': round(adj, 2),\n        'discount': discount,\n        'distribution': dist,\n        'signal': signal,\n    }\n"}],"isError":false,"timestamp":1774225560511}}
