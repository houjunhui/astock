  with open(CHECKPOINT, 'w') as f:\n        json.dump({'idx': idx, 'fetched': fetched, 'failed': failed, 'time': time.time()}, f)\n\nckpt = json.load(open(CHECKPOINT)) if os.path.exists(CHECKPOINT) else {'idx': 0, 'fetched': 0, 'failed': 0}\nstart_idx = ckpt['idx']\nstocks = get_stock_list()\nremaining = stocks[start_idx:]\ntotal = len(stocks)\nprint(f'[{time.strftime(\\\"%H:%M:%S\\\")}] 继续K线抓取: {start_idx}/{total} 只，剩余 {total-start_idx} 只')\n\nbs.login()\nt0 = time.time()\nt0_batch = t0\nbatch_data = []\ntotal_fetched = ckpt['fetched']\ntotal_failed = ckpt['failed']\nMAX_RETRIES = 3\n\nfor i, stock in enumerate(remaining):\n    global_idx = start_idx + i\n    code = stock['code']\n    retries = 0\n    df = None\n    \n    while retries < MAX_RETRIES:\n        try:\n            df = fetch_kline(code, '2024-01-01', '2026-03-20')\n            break\n        except Exception as e:\n            retries += 1\n            if retries >= MAX_RETRIES:\n                print(f'  [{global_idx+1}] {code} 失败({e})，跳过')\n                total_failed += 1\n                break\n            time.sleep(2)\n    \n    if df is not None and len(df) > 0:\n        batch_data.append(df)\n        total_fetched += 1\n    else:\n        total_failed += 1\n\n    if (i + 1) % 100 == 0:\n        elapsed = time.time() - t0_batch\n        speed = 100 / elapsed if elapsed > 0 else 0\n        print(f'  [{global_idx+1}/{total}] 本批100只 {elapsed:.0f}秒 {speed:.1f}只/秒 | 成功{total_fetched} 失败{total_failed} | 总耗时{time.time()-t0:.0f}秒')\n        t0_batch = time.time()\n\n    if len(batch_data) >= BATCH_SIZE:\n        merged = pd.concat(batch_data, ignore_index=True)\n        global_batch = (global_idx // BATCH_SIZE) + 1\n        batch_file = os.path.join(BATCH_DIR, f'batch_{global_batch:03d}.parquet')\n        merged.to_parquet(batch_file, index=False)\n        print(f'  💾 批次{batch_file} {len(merged)}行')\n        batch_data = []\n        save_checkpoint(global_idx + 1, total_fetched, total_failed)\n\n    time.sleep(random.uniform(0.02, 0.07))\n\nif batch_data:\n    merged = pd.concat(batch_data, ignore_index=True)\n    global_batch = (global_idx // BATCH_SIZE) + 1\n    batch_file = os.path.join(BATCH_DIR, f'batch_{global_batch:03d}.parquet')\n    merged.to_parquet(batch_file, index=False)\n    print(f'  💾 最后批次 {batch_file} {len(merged)}行')\n\nsave_checkpoint(total, total_fetched, total_failed)\nbs.logout()\nprint(f'完成! 成功{total_fetched}只 失败{total_failed}只 总耗时{time.time()-t0:.0f}秒')\n\" > /home/gem/workspace/agent/workspace/data/astock/kline/fetch.log 2>&1 &\necho \"后台进程PID: $!\"","background":true}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":128,"output":1261,"cacheRead":29881,"cacheWrite":16050,"totalTokens":47320,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774211522409}}
