path');\\n\\n// 凭证数据\\nconst account = {\\n  ilink_bot_id: '1ad6db4fad22@im.bot',\\n  ilink_user_id: 'o9cq80__6pTaF4_2NWfdc8ecLxlo@im.wechat',\\n  baseurl: 'https://ilinkai.weixin.qq.com',\\n  token: '1ad6db4fad22@im.bot:060000f2c33fdcd6d826708edd5b8f3e294451',\\n  ilink_bot_type: '3'\\n};\\n\\n// 提取accountId (bot_id的原始部分)\\nconst accountId = '1ad6db4fad22';\\n\\n// 状态目录\\nconst stateDir = path.join(process.env.HOME || '/home/gem', '.openclaw/weixin-state');\\nfs.mkdirSync(stateDir, { recursive: true });\\n\\n// 保存accounts目录\\nconst accountsDir = path.join(stateDir, 'accounts');\\nfs.mkdirSync(accountsDir, { recursive: true });\\n\\n// 写入账号文件\\nconst accountPath = path.join(accountsDir, accountId + '.json');\\nfs.writeFileSync(accountPath, JSON.stringify(account, null, 2));\\nconsole.log('账号文件已保存:', accountPath);\\n\\n// 更新index\\nconst indexPath = path.join(stateDir, 'accounts.json');\\nlet index = [];\\nif (fs.existsSync(indexPath)) {\\n  index = JSON.parse(fs.readFileSync(indexPath, 'utf-8'));\\n}\\nif (!index.includes(accountId)) {\\n  index.push(accountId);\\n  fs.writeFileSync(indexPath, JSON.stringify(index, null, 2));\\n  console.log('Index已更新:', indexPath);\\n}\\nconsole.log('完成!');\\n\\\" 2>&1\"} {\n2026-03-23T08:03:40.870+08:00 [36m[feishu/plugin][0m feishu[default][msg:om_x100b533c7b8a30a0b29cd671d34cf72]: tool call: exec params={\"command\":\"ps aux | grep openclaw-gateway | grep -v grep\\necho \\\"---\\\"\\ncat /home/gem/.openclaw/weixin-state/accounts.json 2>/dev/null\\necho \\\"---\\\"\\ncat /home/gem/.openclaw/weixin-state/accounts/1ad6db4fad22.json 2>/dev/null\"} {\n2026-03-23T08:03:46.380+08:00 [36m[feishu/plugin][0m feishu[default][msg:om_x100b533c7b8a30a0b29cd671d34cf72]: tool call: exec params={\"command\":\"tail -30 /tmp/openclaw-gateway.log 2>/dev/null | grep -i \\\"weixin\\\\|wechat\\\\|channel\\\\|openclaw-weixin\\\\|connected\\\\|error\\\" | tail -20\"} {\n2026-03-23T08:03:50.337+08:00 [36m[feishu/plugin][0m feishu[default][msg:om_x100b533