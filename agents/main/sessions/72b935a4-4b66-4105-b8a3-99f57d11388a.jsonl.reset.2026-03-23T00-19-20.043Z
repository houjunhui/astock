{"type":"message","id":"8ca164ca","parentId":"6381a689","timestamp":"2026-03-22T23:33:00.505Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now I need to update the main prediction script to use the sentiment analysis module. Let me update the prediction script to incorporate the sentiment-adjusted probabilities.","thinkingSignature":"216a003a4f677092af2c03767b39ff771c65c40d5af7e68e8eda39a791b7032c"},{"type":"toolCall","id":"call_function_cecwwmjs3cyj_1","name":"exec","arguments":{"command":"cd /home/gem/workspace/agent/workspace/astock && python3 << 'EOF'\nimport sqlite3\nimport sys\nsys.path.insert(0, '.')\nfrom market_sentiment import get_market_sentiment, format_sentiment_report\nimport akshare as ak\nfrom datetime import datetime, timedelta\n\nDB_PATH = '/home/gem/workspace/agent/workspace/data/astock/model/astock.db'\nconn = sqlite3.connect(DB_PATH)\n\n# 1. 情绪报告\nsent = get_market_sentiment(conn)\nprint(format_sentiment_report(sent))\n\n# 2. 校准后的晋级概率（考虑情绪周期）\n# 历史实际晋级率（从回测结果）\nBASE_RATES = {\n    1: 0.20,   # 首板\n    2: 0.28,   # 2板\n    3: 0.35,   # 3板\n    4: 0.25,   # 4板\n    5: 0.15,   # 5板+\n}\n\n# 情绪周期调整系数（与市场情绪配合）\nSENTIMENT_COEF = {\n    'ice':      0.4,   # 冰点大幅打折\n    'withdraw': 0.5,   # 退潮打折\n    'start':    0.7,   # 启动期\n    'ferment':  1.0,   # 发酵期（正常）\n    'peak':     1.2,   # 高潮期（溢价）\n}\n\n# 获取昨日涨停池\nyesterday = (datetime.now() - timedelta(days=1)).strftime('%Y%m%d')\nzt_df = ak.stock_zt_pool_em(date=yesterday)\nprint(f\"\\n昨日涨停({yesterday}): {len(zt_df)}只\\n\")\n\nresults = []\nfor _, row in zt_df.iterrows():\n    code = str(row['代码']).zfill(6)\n    name = str(row.get('名称', ''))\n    lb = int(row.get('连板数', 1) or 1)\n    \n    # 基础晋级概率\n    base_prob = BASE_RATES.get(min(lb+1, 5), 0.15)\n    \n    # 情绪调整\n    sent_coef = SENTIMENT_COEF.get(sent['phase_key'], 0.5)\n    final_prob = min(base_prob * sent_coef, 0.70)\n    \n    results.append({\n        'code': code, 'name': name, 'lb': lb,\n        'base_prob': base_prob * 100,\n        'final_prob': final_prob * 100,\n        'sent_coef': sent_coef,\n        'adj_factor': sent['coef']\n    })\n\nresults.sort(key=lambda x: -x['final_prob'])\n\nprint(\"═\" * 60)\nprint(f\"  【情绪周期校准后晋级概率】  晋级系数: ×{sent_coef:.1f}\")\nprint(\"═\" * 60)\nprint(f\"{'代码':<8} {'名称':<10} {'板位':<5} {'基础%':<8} {'调整后%':<10} {'风险等级'}\")\nprint(\"─\" * 60)\n\nfor r in results:\n    if r['final_prob'] < 10:\n        risk = '⚠️ 谨慎'\n    elif r['final_prob'] < 20:\n        risk = '🔸 观察'\n    elif r['final_prob'] < 35:\n        risk = '✅ 关注'\n    else:\n        risk = '🔥 重点'\n    \n    print(f\"{r['code']:<8} {r['name']:<10} {r['lb']}板   {r['base_prob']:>5.1f}%  {r['final_prob']:>7.1f}%  {risk}\")\n\n# 晋级分布\ngt35 = sum(1 for r in results if r['final_prob'] >= 35)\ngt20 = sum(1 for r in results if 20 <= r['final_prob'] < 35)\ngt10 = sum(1 for r in results if 10 <= r['final_prob'] < 20)\nlt10 = sum(1 for r in results if r['final_prob'] < 10)\n\nprint(f\"\\n晋级概率分布:\")\nprint(f\"  🔥 >35%: {gt35}只\")\nprint(f\"  ✅ 20-35%: {gt20}只\")\nprint(f\"  🔸 10-20%: {gt10}只\")\nprint(f\"  ⚠️ <10%: {lt10}只\")\n\nconn.close()\nEOF\n","timeout":60}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":45910,"output":1062,"cacheRead":29881,"cacheWrite":0,"totalTokens":76853,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774222358679}}
