istent index (no-op if already present). */\n62:export function registerWeixinAccountId(accountId: string): void {\n67:  if (existing.includes(accountId)) return;\n69:  const updated = [...existing, accountId];\n70:  fs.writeFileSync(resolveAccountIndexPath(), JSON.stringify(updated, null, 2), \"utf-8\");\n74:// Account store (per-account credential files)\n77:/** Unified per-account data: token + baseUrl in one file. */\n87:  return path.join(resolveWeixinStateDir(), \"accounts\");\n90:function resolveAccountPath(accountId: string): string {\n91:  return path.join(resolveAccountsDir(), `${accountId}.json`);\n95: * Legacy single-file token: `credentials/openclaw-weixin/credentials.json` (pre per-account files).\n120:/** Load account data by ID, with compatibility fallbacks. */\n121:export function loadWeixinAccount(accountId: string): WeixinAccountData | null {\n122:  // Primary: try given accountId (normalized IDs written after this change).\n123:  const primary = readAccountFile(resolveAccountPath(accountId));\n128:  const rawId = deriveRawAccountId(accountId);","cwd":"/home/gem/workspace/agent/workspace"},"isError":false,"timestamp":1774224115442}}
