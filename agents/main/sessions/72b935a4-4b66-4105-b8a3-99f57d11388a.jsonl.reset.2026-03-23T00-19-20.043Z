{"type":"message","id":"335366a4","parentId":"2fd6dab0","timestamp":"2026-03-22T23:15:01.324Z","message":{"role":"toolResult","toolCallId":"call_function_vvnqxldb9fry_1","toolName":"exec","content":[{"type":"text","text":"样本数: 26308\n有jb_prob: 0\n有outcome: 26308\n('2024-01-03', '000595', 1, '续涨', '维持1板', 1)\n('2024-01-03', '000698', 1, '断板', '大幅下跌', 0)\n('2024-01-03', '000820', 1, '晋级', '1板→2板', 2)"}],"details":{"status":"completed","exitCode":0,"durationMs":40,"aggregated":"样本数: 26308\n有jb_prob: 0\n有outcome: 26308\n('2024-01-03', '000595', 1, '续涨', '维持1板', 1)\n('2024-01-03', '000698', 1, '断板', '大幅下跌', 0)\n('2024-01-03', '000820', 1, '晋级', '1板→2板', 2)","cwd":"/home/gem/workspace/agent/workspace"},"isError":false,"timestamp":1774221301305}}
{"type":"message","id":"3589dea9","parentId":"335366a4","timestamp":"2026-03-22T23:15:35.437Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Ah I see - we wrote the historical data but didn't compute jb_prob. The predictions table has outcome and actual_boards filled, but jb_prob is NULL. We need to compute jb_prob based on lb and the kline data.\n\nLet me now compute the full prediction including jb_prob for each historical record, then run calibration.","thinkingSignature":"318f92ce7292075dac1529856af50eebae9c94d03a496b1cef700fd2854823f3"},{"type":"text","text":"outcome 有了但没算 jb_prob，补上预测概率再跑标定：\n"},{"type":"toolCall","id":"call_function_squno954kwo5_1","name":"exec","arguments":{"command":"cd /home/gem/workspace/agent/workspace/astock && python3 << 'EOF'\n\"\"\"\n为历史预测补全 jb_prob 等字段，然后跑概率标定\n\"\"\"\nimport sys, os\nsys.path.insert(0, '.')\nimport sqlite3\nimport pandas as pd\nfrom config import BASE_PROBS, DEFAULT_COEF\nfrom predict import calc_adj, predict_stock\nfrom collections import defaultdict\n\nDB_PATH = '/home/gem/workspace/agent/workspace/data/astock/model/astock.db'\nBATCH_DIR = '/home/gem/workspace/agent/workspace/data/astock/kline/batches'\n\nprint(\"加载K线...\")\nfiles = sorted([f for f in os.listdir(BATCH_DIR) if f.endswith('.parquet')])\nall_dfs = [pd.read_parquet(os.path.join(BATCH_DIR, f)) for f in files]\nkline = pd.concat(all_dfs, ignore_index=True).dropna(subset=['date', 'code', 'close', 'high', 'open', 'volume'])\n\n# 构建每只股票的K线数据\nkline_dict = {}\nfor code, grp in kline.groupby('code'):\n    grp_sorted = grp.sort_values('date')\n    dates = list(grp_sorted['date'])\n    kline_dict[code] = {'dates': dates, 'data': grp_sorted.set_index('date').to_dict('index')}\n\nprint(f\"K线: {len(kline_dict)}只股票\")\n\nconn = sqlite3.connect(DB_PATH)\n\n# 读取所有历史预测\nrows = conn.execute(\"SELECT date, code, lb, outcome FROM predictions\").fetchall()\nprint(f\"补全 {len(rows)} 条预测...\")\n\nfrom datetime import datetime\n\nfor i, (date, code, lb, outcome) in enumerate(rows):\n    if (i+1) % 5000 == 0:\n        print(f\"  进度 {i+1}/{len(rows)}\")\n    \n    kl = kline_dict.get(code, {}).get('data', {}).get(date)\n    if not kl:\n        continue\n    \n    kl['code'] = code\n    kl['date'] = date\n    \n    # 计算各项指标\n    info = kline_dict[code]\n    dates = info['dates']\n    data = info['data']\n    \n    # MA20, MA60\n    idx = dates.index(date) if date in dates else -1\n    if idx >= 19:\n        ma20_vals = [data[d]['close'] for d in dates[idx-19:idx+1]]\n        kl['ma20'] = sum(ma20_vals) / len(ma20_vals)\n    else:\n        kl['ma20'] = kl.get('close')\n    \n    if idx >= 59:\n        ma60_vals = [data[d]['close'] for d in dates[idx-59:idx+1]]\n        kl['ma60'] = sum(ma60_vals) / len(ma60_vals)\n    else:\n        kl['ma60'] = kl.get('close')\n    \n    # 趋势判断（简化版）\n    if idx >= 5:\n        recent_closes = [data[d]['close'] for d in dates[idx-4:idx+1] if d in data]\n        if len(recent_closes) >= 5:\n            if all(recent_closes[j] > recent_closes[j-1] for j in range(1, len(recent_closes))):\n                kl['trend'] = '上升通道'\n            elif all(recent_closes[j] < recent_closes[j-1] for j in range(1, len(recent_closes))):\n                kl['trend'] = '下降通道'\n            else:\n                kl['trend'] = '震荡'\n        else:\n            kl['trend'] = '震荡'\n    else:\n        kl['trend'] = '震荡'\n    \n    # RSI（简化）\n    if idx >= 14:\n        gains = []\n        losses = []\n        for j in range(idx - 13, idx + 1):\n            if j > 0:\n                prev = data[dates[j-1]]['close']\n                curr = data[dates[j]]['close']\n                if curr > prev:\n                    gains.append(curr - prev)\n                else:\n                    losses.append(abs(curr - prev))\n        avg_gain = sum(gains) / 14 if gains else 0\n        avg_loss = sum(losses) / 14 if losses else 0\n        if avg_loss == 0:\n            kl['rsi'] = 100\n        else:\n            rs = avg_gain / avg_loss\n            kl['rsi'] = 100 - (100 / (1 + rs))\n    else:\n        kl['rsi'] = 50\n    \n    # 量比（简化：当日成交量/前5日均量）\n    if idx >= 5:\n        vol_history = [data[dates[j]]['volume'] for j in range(idx-4, idx+1) if dates[j] in data]\n        if len(vol_history) >= 5 and sum(vol_history[:-1]) > 0:\n            avg_vol = sum(vol_history[:-1]) / len(vol_history[:-1])\n            kl['vr'] = vol_history[-1] / avg_vol if avg_vol > 0 else 1\n        else:\n            kl['vr'] = 1\n    else:\n        kl['vr'] = 1\n    \n    # MACD简化\n    if idx >= 26:\n        ema12 = kl['close']  # 简化\n        ema26 = kl['close']\n        kl['macd'] = 0\n        kl['dif'] = 0\n    else:\n        kl['macd'] = 0\n        kl['dif'] = 0\n    \n    kl['last_close'] = kl.get('close', 0)\n    kl['price_vs_ma20'] = 'MA20上方' if kl.get('close', 0) > kl.get('ma20', 0) else 'MA20下方'\n    \n    pred = predict_stock(code, lb, kl)\n    \n    conn.execute(\"\"\"\n        UPDATE predictions SET \n            jb_prob=?, dz_prob=?, base_prob=?, adj_factor=?,\n            signal=?, dist_N=?, dist_N1=?, dist_N2=?,\n            rsi=?, vr=?, macd_state=?, vol_status=?, price_vs_ma20=?,\n            trend=?\n        WHERE date=? AND code=?\n    \"\"\", (\n        pred['jb_prob'], pred['dz_prob'], pred['base_prob'], pred['adj_factor'],\n        pred['signal'],\n        pred['distribution'][1], pred['distribution'][2], pred['distribution'][3],\n        round(kl.get('rsi', 0), 1) if kl.get('rsi') else None,\n        round(kl.get('vr', 1), 2) if kl.get('vr') else None,\n        kl.get('macd_state', ''),\n        kl.get('vol_status', ''),\n        kl.get('price_vs_ma20', ''),\n        kl.get('trend', '震荡'),\n        date, code\n    ))\n\nconn.commit()\nprint(\"补全完成!\")\n\n# 跑概率标定\nprint(\"\\n概率标定:\")\nrows = conn.execute(\"SELECT jb_prob, lb, outcome FROM predictions WHERE outcome IS NOT NULL AND jb_prob IS NOT NULL\").fetchall()\nbuckets = defaultdict(lambda: {'total': 0, 'actual_jb': 0, 'pred_sum': 0})\n\nfor jb_prob, lb, outcome in rows:\n    bucket = int(jb_prob // 5)\n    buckets[bucket]['total'] += 1\n    buckets[bucket]['pred_sum'] += jb_prob\n    if outcome == '晋级':\n        buckets[bucket]['actual_jb'] += 1\n\nprint(f\"{'桶':<8} {'预测均值':<10} {'实际率':<10} {'样本':<8} {'偏差'}\")\nprint(\"-\" * 45)\nfor bucket in sorted(buckets.keys()):\n    d = buckets[bucket]\n    if d['total'] < 20:\n        continue\n    pred_avg = d['pred_sum'] / d['total']\n    actual = d['actual_jb'] / d['total'] * 100\n    bias = actual - pred_avg\n    low = bucket * 5\n    high = (bucket + 1) * 5\n    print(f\"{low:>3}-{high:<3}%  {pred_avg:>7.1f}%  {actual:>7.1f}%  {d['total']:<8} {bias:>+.1f}%\")\n\ntotal = sum(d['total'] for d in buckets.values())\nactual_total = sum(d['actual_jb'] for d in buckets.values())\nprint(f\"\\n总体: {actual_total}/{total} = {actual_total/total*100:.1f}%\")\n\n# 结局分布\noutcomes = defaultdict(int)\nfor _, _, outcome in rows:\n    outcomes[outcome] += 1\nprint(\"\\n结局分布:\")\nfor k, v in sorted(outcomes.items(), key=lambda x: -x[1]):\n    print(f\"  {k}: {v} ({v/len(rows)*100:.1f}%)\")\n\nconn.close()\nEOF\n","timeout":120}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":112942,"output":2104,"cacheRead":29881,"cacheWrite":0,"totalTokens":144927,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774221301321}}
