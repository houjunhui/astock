■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■                |  80% of 110.9 MiB\n|■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■        |  90% of 110.9 MiB\n|■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■| 100% of 110.9 MiB\nChrome Headless Shell 145.0.7632.6 (playwright chromium-headless-shell v1208) downloaded to /home/gem/.cache/ms-playwright/chromium_headless_shell-1208","cwd":"/home/gem/workspace/agent/workspace"},"isError":false,"timestamp":1774212425774}}
{"type":"message","id":"bced1891","parentId":"5c8cf59e","timestamp":"2026-03-22T20:47:42.947Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Good, chromium is now installed. Let me now write a browser-based crawler that can handle these anti-scraping sites.","thinkingSignature":"0d73dcdb4ca54131f331e2c134b42bc1281af07111d4390117389147f6e6c306"},{"type":"toolCall","id":"call_function_n5b3ieunv1hy_1","name":"write","arguments":{"path":"/home/gem/workspace/agent/workspace/gouzai/scripts/browser_crawler.py","content":"\"\"\"\n狗仔 - 浏览器爬虫（处理反爬网站）\n使用 playwright 渲染页面后提取数据\n\"\"\"\nimport sys, os, json, time\nsys.path.insert(0, os.path.dirname(os.path.dirname(__file__)) or '.')\n\nfrom datetime import datetime\nfrom crawler import save, log_crawl, get_db\nfrom crawler import fetch as http_fetch, HEADERS\n\n# ===================== Playwright 爬虫 =====================\ndef get_browser():\n    \"\"\"延迟导入，避免启动时就报错\"\"\"\n    from playwright.sync_api import sync_playwright\n    p = sync_playwright().start()\n    browser = p.chromium.launch(\n        headless=True,\n        args=['--no-sandbox', '--disable-dev-shm-usage', '--disable-gpu', '--disable-setuid-sandbox']\n    )\n    return p, browser\n\ndef close_browser(p):\n    try:\n        p.stop()\n    except:\n        pass\n\ndef crawl_cailian_browser():\n    \"\"\"财联社 - 用浏览器渲染\"\"\"\n    items = []\n    try:\n        from playwright.sync_api import sync_playwright\n        with sync_playwright() as p:\n            browser = p.chromium.launch(\n                headless=True,\n                args=['--no-sandbox', '--disable-dev-shm-usage', '--disable-gpu']\n            )\n            page = browser.new_page()\n            page.goto('https://www.cls.cn/telegraph', wait_until='domcontentloaded', timeout=15000)\n            page.wait_for_timeout(3000)\n            \n            # 滚动加载更多\n            page.evaluate('window.scrollBy(0, 500)')\n            page.wait_for_timeout(1000)\n            \n            # 提取数据\n            articles = page.query_selector_all('div.telegraph-item, .article-item, [class*=\"telegraph\"]')\n            for art in articles[:20]:\n                try:\n                    title_el = art.query_selector('h3, .title, a')\n                    time_el = art.query_selector('.time, .date, span')\n                    link_el = art.query_selector('a')\n                    \n                    title = title_el.inner_text().strip() if title_el else ''\n                    href = link_el.get_attribute('href') if link_el else ''\n                    time_str = time_el.inner_text().strip() if time_el else ''\n                    \n                    if title and 'cls.cn' not in href:\n                        href = 'https://www.cls.cn' + href if href.startswith('/') else href\n                    \n                    if title:\n                        items.append({\n                            'title': title[:100],\n                            'summary': '',\n                            'source': '财联社',\n                            'url': href,\n                            'category': '资讯',\n                            'published_at': time_str,\n                            'importance': 2 if any(k in title for k in ['利好', '利空', '监管', '公告', '突发']) else 1,\n                        })\n                except Exception:\n                    continue\n            \n            browser.close()\n    except Exception as e:\n        print(f\"  财联社浏览器失败: {e}\")\n    return items\n\ndef crawl_xueqiu_browser():\n    \"\"\"雪球 - 用浏览器获取\"\"\"\n    items = []\n    try:\n        from playwright.sync_api import sync_playwright\n        with sync_playwright() as p:\n            browser = p.chromium.launch(\n                headless=True,\n                args=['--no-sandbox', '--disable-dev-shm-usage', '--disable-gpu']\n            )\n            page = browser.new_page()\n            \n            # 先访问首页获取cookie\n            page.goto('https://xueqiu.com/', wait_until='domcontentloaded', timeout=15000)\n            page.wait_for_timeout(2000)\n            \n            # 访问热帖页面\n            page.goto('https://xueqiu.com/hot', wait_until='domcontentloaded', timeout=15000)\n            page.wait_for_timeout(2000)\n            \n            # 提取热门股票\n            stocks = page.query_selector_all('.stock-item, [class*=\"stock\"]')\n            for stock in stocks[:10]:\n                try:\n                    name_el = stock.query_selector('.name, .stock-name, a')\n                    link_el = stock.query_selector('a')\n                    title = name_el.inner_text().strip() if name_el else ''\n                    href = link_el.get_attribute('href') if link_el else ''\n                    if title and href:\n                        items.append({\n                            'title': f'雪球热帖: {title}',\n                            'summary': '',\n                            'source': '雪球',\n                            'url': 'https://xueqiu.com' + href if href.startswith('/') else href,\n                            'category': '社区',\n                            'published_at': '',\n                            'importance': 1,\n                        })\n                except Exception:\n                    continue\n            \n            browser.close()\n    except Exception as e:\n        print(f\"  雪球浏览器失败: {e}\")\n    return items\n\ndef crawl_taoguba_browser():\n    \"\"\"淘股吧 - 用浏览器\"\"\"\n    items = []\n    try:\n        from playwright.sync_api import sync_playwright\n        with sync_playwright() as p:\n            browser = p.chromium.launch(\n                headless=True,\n                args=['--no-sandbox', '--disable-dev-shm-usage', '--disable-gpu']\n            )\n            page = browser.new_page()\n            page.goto('https://www.taoguba.com.cn/', wait_until='domcontentloaded', timeout=15000)\n            page.wait_for_timeout(2000)\n            \n            # 提取帖子列表\n            posts = page.query_selector_all('.article-item, .post-item, tr[data-id]')\n            for post in posts[:20]:\n                try:\n                    title_el = post.query_selector('.article-title, .title, a')\n                    author_el = post.query_selector('.author, .user-name')\n                    time_el = post.query_selector('.time, .date')\n                    link_el = post.query_selector('a')\n                    \n                    title = title_el.inner_text().strip() if title_el else ''\n                    author = author_el.inner_text().strip() if author_el else ''\n                    time_str = time_el.inner_text().strip() if time_el else ''\n                    href = link_el.get_attribute('href') if link_el else ''\n                    \n                    if title:\n                        href = 'https://www.taoguba.com.cn' + href if href.startswith('/') else href\n                        items.append({\n                            'title': title[:100],\n                            'summary': f'作者: {author}' if author else '',\n                            'source': '淘股吧',\n                            'url': href,\n                            'category': '论坛',\n                            'published_at': time_str,\n                            'importance': 1,\n                        })\n                except Exception:\n                    continue\n            \n            browser.close()\n    except Exception as e:\n        print(f\"  淘股吧浏览器失败: {e}\")\n    return items\n\n\ndef crawl_with_browser():\n    \"\"\"用浏览器爬取所有需要渲染的站点\"\"\"\n    print(f\"[{datetime.now().strftime('%H:%M:%S')}] 浏览器爬取模式...\")\n    \n    all_items = []\n    \n    # 财联社\n    try:\n        items = crawl_cailian_browser()\n        saved = sum(save(item) for item in items)\n        print(f\"  财联社: {len(items)}条, 新增{saved}条\")\n        log_crawl('财联社(浏览器)', saved, 'ok')\n        all_items.extend(items)\n    except Exception as e:\n        print(f\"  财联社: 失败 {e}\")\n        log_crawl('财联社(浏览器)', 0, 'error', str(e))\n    \n    time.sleep(2)\n    \n    # 雪球\n    try:\n        items = crawl_xueqiu_browser()\n        saved = sum(save(item) for item in items)\n        print(f\"  雪球: {len(items)}条, 新增{saved}条\")\n        log_crawl('雪球(浏览器)', saved, 'ok')\n        all_items.extend(items)\n    except Exception as e:\n        print(f\"  雪球: 失败 {e}\")\n        log_crawl('雪球(浏览器)', 0, 'error', str(e))\n    \n    time.sleep(2)\n    \n    # 淘股吧\n    try:\n        items = crawl_taoguba_browser()\n        saved = sum(save(item) for item in items)\n        print(f\"  淘股吧: {len(items)}条, 新增{saved}条\")\n        log_crawl('淘股吧(浏览器)', saved, 'ok')\n        all_items.extend(items)\n    except Exception as e:\n        print(f\"  淘股吧: 失败 {e}\")\n        log_crawl('淘股吧(浏览器)', 0, 'error', str(e))\n    \n    return all_items\n\n\nif __name__ == '__main__':\n    crawl_with_browser()\n"}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":51098,"output":1931,"cacheRead":29881,"cacheWrite":0,"totalTokens":82910,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774212425787}}
