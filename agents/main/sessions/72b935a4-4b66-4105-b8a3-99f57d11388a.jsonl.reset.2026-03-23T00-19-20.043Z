en(merged)}行')  save_checkpoint(total, total_fetched, total_failed) bs.logout() print(f'完成! 成功{total_fetched}只 失败{total_failed}只 总耗时{time.time()-t0:.0f}秒') \" > /home/gem/workspace/agent/workspace/data/astock/kline/fetch.log 2>&1 & echo \"后台进程PID: $!\"\ngem       301485  5.0  3.0 1420024 109420 ?      Sl   04:32   0:00 python3 -c  import sys, os, time, random, json sys.path.insert(0, '.') import baostock as bs import pandas as pd  DATA_DIR = '/home/gem/workspace/agent/workspace/data/astock/kline' BATCH_DIR = os.path.join(DATA_DIR, 'batches') BATCH_SIZE = 500 CHECKPOINT = os.path.join(DATA_DIR, 'fetch_checkpoint.json') STOCK_LIST_PATH = '/home/gem/workspace/agent/workspace/data/astock/stock_list.json'  def code_to_bs(code):     code = str(code).zfill(6)     return f'sh.{code}' if code.startswith(('6', '9')) else f'sz.{code}'  def get_stock_list():     with open(STOCK_LIST_PATH) as f:         stocks = json.load(f)     return [s for s in stocks if s.get('code','').startswith(('6', '000', '001', '002', '003', '300', '688'))]  def fetch_kline(code, start, end):     rs = bs.query_history_k_data_plus(code_to_bs(code),         'date,open,high,low,close,volume,amount',         start_date=start, end_date=end, frequency='d', adjustflag='2')     if rs.error_msg != 'success':         return None     rows = []     while rs.next():         rows.append(rs.get_row_data())     if not rows:         return None     df = pd.DataFrame(rows, columns=['date','open','high','low','close','volume','amount'])     df['code'] = code     for col in ['open','high','low','close','volume','amount']:         df[col] = pd.to_numeric(df[col], errors='coerce')     return df  def save_checkpoint(idx, fetched, failed):     with open(CHECKPOINT, 'w') as f:         json.dump({'idx': idx, 'fetched': fetched, 'failed': failed, 'time': time.time()}, f)  ckpt = json.load(open(CHECKPOINT)) if os.path.exists(CHECKPOINT) else {'idx': 0, 'fetched': 0, 'failed': 0} start_idx = ckpt['idx'] stocks = get_stock_list() r